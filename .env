# ─── REQUIRED SECRETS (generate before first run) ────────────────────────────
# Run this to generate each secret:
#   python -c "import secrets; print(secrets.token_hex(32))"
#
# BUG-9 FIX: The default JWT algorithm is RS256 which requires an RSA key pair.
# .env previously shipped only RHODAWK_JWT_SECRET (for HS256) with no RSA vars,
# causing a hard crash at FastAPI startup on every first run.
#
# For quick-start / development: use HS256 with a strong secret (below).
# For production: use RS256 with a generated key pair (see commented block).
#
# ── HS256 (quick start / single-node development) ─────────────────────────────
RHODAWK_JWT_ALGORITHM=HS256
# MUST be ≥64 chars of high-entropy random hex. Replace the placeholder:
RHODAWK_JWT_SECRET=564f25358aa940ef11871520fccf5c8c4505dcbfc1f43aa8fdc1dc2321bfe3e5
#
# ── RS256 (production / multi-node) ───────────────────────────────────────────
# Generate with:
#   openssl genrsa -out rhodawk_private.pem 2048
#   openssl rsa -in rhodawk_private.pem -pubout -out rhodawk_public.pem
# Then set (use export or inject via docker-compose env_file):
# RHODAWK_JWT_ALGORITHM=RS256
# RHODAWK_JWT_PRIVATE_KEY=<paste contents of rhodawk_private.pem>
# RHODAWK_JWT_PUBLIC_KEY=<paste contents of rhodawk_public.pem>

# SEC-4 FIX: RHODAWK_AUDIT_SECRET must be a non-empty, non-placeholder, ≥32-char
# random string. An empty or known placeholder produces HMAC signatures anyone
# who reads this file can forge — invalidating the tamper-evident audit trail.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
RHODAWK_AUDIT_SECRET=cf0e12e43c51517a31019d9b7777f57db0f0e6970c8baacf7d818da8318e6f69

# ─── LLM API Keys ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=sk-or-...    # for Llama4/Devstral/Codex
# OPENAI_API_KEY=sk-...        # optional direct OpenAI
#
# NOTE (Bug 8): Placeholder values above (sk-ant-..., sk-or-...) are detected
# by _is_cloud_configured() and treated as "no cloud key configured". Cloud
# routing will not be attempted until you replace them with real keys.

# ─── Local models (Ollama) ───────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
# Pull models:
#   ollama pull qwen2.5-coder:32b      # Fixer A (required)
#   ollama pull deepseek-coder-v2      # Fixer B (required for BoBN)
#   ollama pull llama3.3:70b           # Critic  (required for BoBN — Meta family)
#   ollama pull mistral:7b             # Synthesis (required for BoBN — Mistral family)
#   ollama pull granite-code:8b        # Light judge (optional)

# ─── Vector / memory stores ──────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=...           # only for Qdrant Cloud

# ─── GitHub integration ──────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...

# ─── Database (PostgreSQL for scale) ─────────────────────────────────────────
# POSTGRES_PASSWORD is required by docker-compose.yml (uses :? mandatory syntax).
# docker-compose up WILL FAIL if this is not set.
# Generate: python -c "import secrets; print(secrets.token_hex(16))"
POSTGRES_USER=rhodawk
POSTGRES_PASSWORD=ec1498ee15e57f018bf489bb3884baeb
POSTGRES_DB=rhodawk
# Once the above are set, enable PostgreSQL storage by uncommenting:
# RHODAWK_PG_DSN=postgresql+asyncpg://rhodawk:${POSTGRES_PASSWORD}@postgres:5432/rhodawk

# ─── Task queue ──────────────────────────────────────────────────────────────
REDIS_PASSWORD=9180df0e15276ee448ac4d414723cd9d
REDIS_URL=redis://:9180df0e15276ee448ac4d414723cd9d@redis:6379/0

# ─── Formal verification ─────────────────────────────────────────────────────
# LEAN4_BINARY=/usr/local/bin/lean
# RHODAWK_FORMAL_TIMEOUT=60

# ─── Webhook (required in production) ────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# RHODAWK_WEBHOOK_SECRET=CHANGE_ME_generate_with_python

# ─── Development only ────────────────────────────────────────────────────────
# WARNING: RHODAWK_DEV_AUTH=1 disables ALL API authentication.
# NEVER set this in production. It is intentionally commented out here.
# For local development only, uncomment this line in a local .env.local file
# that is NOT committed to version control.
#
# RHODAWK_DEV_AUTH=1

# ─── Feature flags ───────────────────────────────────────────────────────────
RHODAWK_FORCE_CLOUD=0         # 1 = skip local models entirely
HELIX_USE_LOCAL_QDRANT=0      # 1 = use in-memory Qdrant (no server)
TOOLHIVE_DISABLE=0            # 1 = disable all MCP tools

# ─── Gap 1: Joern CPG configuration ──────────────────────────────────────────
# Joern builds the Code Property Graph (AST + CFG + PDG) for causal context.
# Without Joern, context selection falls back to hybrid BM25+dense retrieval.
#
# JOERN_URL: Joern server URL (matches docker-compose joern service)
JOERN_URL=http://localhost:8080
#
# JOERN_REPO_PATH: Absolute path to the repository being audited ON THE HOST.
# This path is bind-mounted into the Joern container as /repo (read-only).
# Leave empty to mount an empty placeholder directory (CPG will be inactive).
# Example: JOERN_REPO_PATH=/home/user/myproject
JOERN_REPO_PATH=
#
# JOERN_PROJECT_NAME: Logical project name in Joern workspace.
JOERN_PROJECT_NAME=rhodawk
#
# CPG_ENABLED: Set to 0 to disable CPG and use vector search only.
CPG_ENABLED=1
#
# CPG_BLAST_RADIUS_THRESHOLD: Functions above this count → require human review.
CPG_BLAST_RADIUS_THRESHOLD=50

# ─── Gap 5: Adversarial BoBN ensemble ────────────────────────────────────────
# Four-model pipeline: Fixer A (Alibaba) + Fixer B (DeepSeek) +
#                      Adversarial Critic (Meta) + Synthesis (Mistral)
# Each role MUST come from a different model family.
# router.assert_family_independence() enforces this at startup.
#
# BUG-1 FIX: Critic and Synthesis tiers now have Ollama fallbacks so a fully
# local Ollama-only deployment can run the complete BoBN pipeline without
# OPENROUTER_API_KEY. Pull the required models (see Ollama section above).
#
RHODAWK_GAP5_ENABLED=true
#
VLLM_SECONDARY_BASE_URL=http://localhost:8001/v1
VLLM_SECONDARY_MODEL=deepseek-ai/DeepSeek-Coder-V2-Lite-Instruct
#
# Leave empty to use Ollama fallback (ollama/llama3.3:70b) or OpenRouter
VLLM_CRITIC_BASE_URL=
VLLM_CRITIC_MODEL=meta-llama/Llama-3.3-70B-Instruct
#
# Leave empty to use Ollama fallback (ollama/mistral:7b) or OpenRouter
VLLM_SYNTHESIS_BASE_URL=
VLLM_SYNTHESIS_MODEL=mistralai/Devstral-Small-2505
#
RHODAWK_BOBN_CANDIDATES=10
RHODAWK_BOBN_FIXER_A=6
RHODAWK_BOBN_FIXER_B=4
#
RHODAWK_CRITIC_W_TEST=0.6
RHODAWK_CRITIC_W_ROBUST=0.3
RHODAWK_CRITIC_W_MIN=0.1

# ─── Upload limits ────────────────────────────────────────────────────────────
# MISSING-4 FIX: concurrent upload cap prevents OOM from simultaneous 2 GB zips
RHODAWK_MAX_CONCURRENT_UPLOADS=5
# ADD-4: bound reader RAM = concurrency × max_file_bytes
# At defaults (4 × 5 MB = 20 MB peak) this is safe. Raise with care.
RHODAWK_MAX_FILE_BYTES=5242880   # 5 MB per file
# ARCH-1: cap total files collected per run
RHODAWK_MAX_FILES=50000
