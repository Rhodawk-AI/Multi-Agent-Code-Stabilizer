language = "python3"
run = "pytest tests/unit/ -v"
modules = ["python-3.11", "web", "rust-stable", "bash"]

[nix]
channel = "stable-25_05"
packages = ["cargo", "libiconv", "libxcrypt", "libyaml", "openssl", "pkg-config", "postgresql", "rustc"]

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "uvicorn api.app:app --host 0.0.0.0 --port 8000 --reload"
waitForPort = 8000

