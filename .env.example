# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Rhodawk AI Code Stabilizer
#
# Copy this file to .env and fill in real values before running.
# NEVER commit .env — it is in .gitignore for a reason.
#
#   cp .env.example .env
#   # then edit .env with your actual secrets
#
# Generate secrets with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# ─────────────────────────────────────────────────────────────────────────────

# ─── REQUIRED SECRETS (generate before first run) ────────────────────────────
RHODAWK_JWT_SECRET=CHANGE_ME_generate_with_python_secrets_token_hex_32
RHODAWK_AUDIT_SECRET=CHANGE_ME_generate_with_python_secrets_token_hex_32

# ─── LLM API Keys ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME
OPENROUTER_API_KEY=sk-or-CHANGE_ME
# OPENAI_API_KEY=sk-CHANGE_ME        # optional direct OpenAI

# ─── Local models (Ollama) ───────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
# Pull: ollama pull granite4-tiny && ollama pull granite4-small

# ─── Vector / memory stores ──────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=CHANGE_ME           # only for Qdrant Cloud

# ─── GitHub integration ──────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_CHANGE_ME

# ─── Database (PostgreSQL for scale) ─────────────────────────────────────────
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/rhodawk

# ─── Task queue ──────────────────────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379/0

# ─── Formal verification ─────────────────────────────────────────────────────
# LEAN4_BINARY=/usr/local/bin/lean
# RHODAWK_FORMAL_TIMEOUT=60

# ─── Webhook (required in production) ────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
RHODAWK_WEBHOOK_SECRET=CHANGE_ME_generate_with_python_secrets_token_hex_32

# ─── Federation ──────────────────────────────────────────────────────────────
# Required in production to prevent unauthenticated pattern injection.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
RHODAWK_FED_TOKEN=CHANGE_ME_generate_with_python_secrets_token_hex_32

# ─── Development only — READ CAREFULLY ──────────────────────────────────────
#
# WARNING: RHODAWK_DEV_AUTH=1 disables ALL API authentication.
# NEVER set this in production. The application will refuse to start if
# RHODAWK_DEV_AUTH=1 and RHODAWK_ENV != 'development'.
#
# For local development only: uncomment the two lines below in YOUR LOCAL .env
# (which is git-ignored and must never be committed).
#
# RHODAWK_ENV=development
# RHODAWK_DEV_AUTH=1

# ─── Feature flags ───────────────────────────────────────────────────────────
RHODAWK_FORCE_CLOUD=0         # 1 = skip local models entirely
HELIX_USE_LOCAL_QDRANT=0      # 1 = use in-memory Qdrant (no server)
TOOLHIVE_DISABLE=0            # 1 = disable all MCP tools

# ─── Gap 1: Joern CPG configuration ──────────────────────────────────────────
JOERN_URL=http://localhost:8080
JOERN_REPO_PATH=               # Absolute path to the repository on the HOST
JOERN_PROJECT_NAME=rhodawk
CPG_ENABLED=1
CPG_BLAST_RADIUS_THRESHOLD=50

# ─── Gap 5: Adversarial BoBN ensemble ────────────────────────────────────────
# Four-model pipeline — each role MUST be a different model family.
# router.assert_family_independence() enforces this at startup.
RHODAWK_GAP5_ENABLED=true

VLLM_PRIMARY_BASE_URL=http://localhost:8000/v1
VLLM_PRIMARY_MODEL=Qwen/Qwen2.5-Coder-32B-Instruct

VLLM_SECONDARY_BASE_URL=http://localhost:8001/v1
VLLM_SECONDARY_MODEL=deepseek-ai/DeepSeek-Coder-V2-Lite-Instruct

VLLM_CRITIC_BASE_URL=          # leave blank to use OpenRouter
VLLM_CRITIC_MODEL=meta-llama/Llama-3.3-70B-Instruct

VLLM_SYNTHESIS_BASE_URL=       # leave blank to use OpenRouter
VLLM_SYNTHESIS_MODEL=mistralai/Devstral-Small-2505

RHODAWK_BOBN_CANDIDATES=10
RHODAWK_BOBN_FIXER_A=6
RHODAWK_BOBN_FIXER_B=4

RHODAWK_CRITIC_W_TEST=0.6
RHODAWK_CRITIC_W_ROBUST=0.3
RHODAWK_CRITIC_W_MIN=0.1
