# ─── REQUIRED SECRETS (generate before first run) ───────────────────────────
# python -c "import secrets; print(secrets.token_hex(32))"
RHODAWK_JWT_SECRET=CHANGE_ME_generate_with_python
RHODAWK_AUDIT_SECRET=CHANGE_ME_generate_with_python

# ─── LLM API Keys ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=sk-or-...    # for Llama4/Devstral/Codex
# OPENAI_API_KEY=sk-...        # optional direct OpenAI

# ─── Local models (Ollama) ───────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
# Pull: ollama pull granite4-tiny && ollama pull granite4-small

# ─── Vector / memory stores ──────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=...           # only for Qdrant Cloud

# ─── GitHub integration ──────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...

# ─── Database (PostgreSQL for scale) ─────────────────────────────────────────
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/rhodawk

# ─── Task queue ──────────────────────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379/0

# ─── Formal verification ─────────────────────────────────────────────────────
# LEAN4_BINARY=/usr/local/bin/lean
# RHODAWK_FORMAL_TIMEOUT=60

# ─── Development only ────────────────────────────────────────────────────────
RHODAWK_DEV_AUTH=1   # set to 1 to accept any token in /auth/token

# ─── Feature flags ───────────────────────────────────────────────────────────
RHODAWK_FORCE_CLOUD=0         # 1 = skip local models entirely
HELIX_USE_LOCAL_QDRANT=0      # 1 = use in-memory Qdrant (no server)
TOOLHIVE_DISABLE=0            # 1 = disable all MCP tools

# ─── Gap 1: Joern CPG configuration ──────────────────────────────────────────
# Joern builds the Code Property Graph (AST + CFG + PDG) for causal context.
# Without Joern, context selection falls back to hybrid BM25+dense retrieval.
#
# JOERN_URL: Joern server URL (matches docker-compose joern service)
JOERN_URL=http://localhost:8080
#
# JOERN_REPO_PATH: Absolute path to the repository being audited ON THE HOST.
# This path is bind-mounted into the Joern container as /repo (read-only).
# Example: JOERN_REPO_PATH=/home/user/myproject
JOERN_REPO_PATH=
#
# JOERN_PROJECT_NAME: Logical project name in Joern workspace.
JOERN_PROJECT_NAME=rhodawk
#
# CPG_ENABLED: Set to 0 to disable CPG and use vector search only.
CPG_ENABLED=1
#
# CPG_BLAST_RADIUS_THRESHOLD: Functions above this count → require human review.
CPG_BLAST_RADIUS_THRESHOLD=50
