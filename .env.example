# RHODAWK AI CODE STABILIZER Environment Configuration
# Copy to .env and fill in your values

# ── Required ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GITHUB_TOKEN=your_github_token_here  # needs: repo, pull_requests, contents

# ── Optional — additional LLM providers ───────────────────────
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=

# ── Ollama (local models) ──────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ── RHODAWK AI CODE STABILIZER Settings ─────────────────────────────────────────
PRIMARY_MODEL=claude-sonnet-4-20250514
FALLBACK_MODELS=gpt-4o-mini,ollama/qwen2.5-coder:32b
MAX_CYCLES=50
COST_CEILING_USD=50.0
CONCURRENCY=4
LOG_LEVEL=INFO
