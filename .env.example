# ─────────────────────────────────────────────────────────────────────────────
# MACS — Multi-Agent Code Stabilizer
# Environment Configuration
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GITHUB_TOKEN=your_github_token_here    # scopes: repo, pull_requests, contents

# ── Optional — additional LLM providers ──────────────────────────────────────
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=

# ── Ollama (local models) ─────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ── Core MACS settings ───────────────────────────────────────────────────────
MACS_PRIMARY_MODEL=claude-sonnet-4-20250514
MACS_CRITICAL_MODEL=claude-opus-4-20250514
MACS_TRIAGE_MODEL=claude-haiku-4-5-20251001
MACS_AUDIT_MODEL=claude-sonnet-4-20250514
MACS_MAX_CYCLES=50
MACS_COST_CEILING=50.0
MACS_CONCURRENCY=4

# ── Domain mode ──────────────────────────────────────────────────────────────
# general | finance | medical | military | embedded
# finance:  PCI-DSS, no float on monetary values, Z3 balance proofs
# medical:  IEC 62304, HIPAA, dosage safety, alarm gates
# military: MISRA-C, DO-178C, no malloc, no goto
# embedded: RTOS rules, bounded loops, no stdio in handlers
MACS_DOMAIN_MODE=general

# ── Graph engine ─────────────────────────────────────────────────────────────
MACS_GRAPH_ENABLED=true
MACS_GRAPH_BACKEND=networkx     # networkx | neo4j
# (only used when backend=neo4j)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# ── Vector store ──────────────────────────────────────────────────────────────
MACS_VECTOR_STORE=false         # set true to enable semantic code search
MACS_VECTOR_PATH=.stabilizer/vectors

# ── Formal verification ───────────────────────────────────────────────────────
MACS_FORMAL_ENABLED=false       # set true for finance/medical/military
MACS_FORMAL_TIMEOUT=30

# ── Static analysis ───────────────────────────────────────────────────────────
MACS_RUN_MYPY=true
MACS_RUN_SEMGREP=true
MACS_RUN_BANDIT=true
MACS_FAIL_ON_WARNING=false

# ── GitHub settings ───────────────────────────────────────────────────────────
MACS_BASE_BRANCH=main
MACS_BRANCH_PREFIX=stabilizer

# ── API server ────────────────────────────────────────────────────────────────
MACS_API_PORT=8000

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
